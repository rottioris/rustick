{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pomodoro Timer",
  "version": "0.1.4",
  "identifier": "com.pomodoro.timer",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pomodoro Timer",
        "width": 320,
        "height": 480,
        "resizable": false,
        "center": true,
        "decorations": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "A minimalist Pomodoro timer",
    "longDescription": "A cross-platform Pomodoro timer application with customizable work/break intervals, system tray support, and native notifications.",
    "category": "Productivity",
    "publisher": "Ori"
  }
}